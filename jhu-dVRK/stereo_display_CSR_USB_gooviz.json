{
  "type": "dd::display_config@1.0.0",
  "name": "dvrk_display",
  "dvrk_console_namespace": "console1",
  "camera": {
    "size": {
      "width": 640,
      "height": 480
    },
    "left": {
      "stream": "v4l2src device=/dev/video0"
    },
    "right": {
      "stream": "v4l2src device=/dev/video2"
    }
  },
  "preserve_size": true,
  "sinks": [
    "glimage"
  ]
}
