{
  "type": "dd::display_config@1.0.0",
  "name": "dvrk_display",
  "unixfdsinks": [
    {
      "stream": "stereo"
    }
  ],
  "dvrk_console_namespace": "console",
  "camera": {
    "size": {
      "width": 1920,
      "height": 1080
    },
    "left": {
      "stream": "decklinkvideosrc device-number=0 connection=hdmi mode=1080p60 video-format=8bit-bgra"
    },
    "right": {
      "stream": "decklinkvideosrc device-number=1 connection=hdmi mode=1080p60 video-format=8bit-bgra"
    }
  },
  "preserve_size": true,
  "display_horizontal_offset_px": 0,
  "sinks": [
    "glimage"
  ]
}
